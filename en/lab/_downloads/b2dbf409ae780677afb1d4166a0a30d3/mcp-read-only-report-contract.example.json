      "examplePath": "docs/examples/mcp-audit-event.example.json",
      "state": "available_as_data"
    }
  ],
  "reportSections": [
    {
      "sectionId": "lab_status_summary",
      "sourceBoundary": "pccx.lab.status.v0",
      "outputKind": "status_summary_section",
      "sectionState": "example_only",
      "summary": "Conservative lab status and evidence markers.",
      "summaryOnly": true,
      "itemLimit": 4,
      "artifactWrite": false,
      "repositoryMutation": false,
      "privatePathEchoAllowed": false,
      "stdoutIncluded": false,
      "stderrIncluded": false,
      "rawLogIncluded": false,
      "fieldDescriptors": [
        {
          "fieldName": "labMode",
          "valueKind": "bounded-string",
          "policy": "copied from status JSON only"
        },
        {
          "fieldName": "evidenceState",
          "valueKind": "metadata-object",
          "policy": "conservative marker values only; no hardware proof is implied"
        }
      ]
    },
    {
      "sectionId": "workflow_descriptor_summary",
      "sourceBoundary": "pccx.lab.workflow-descriptors.v0",
      "outputKind": "descriptor_catalog_section",
      "sectionState": "example_only",
      "summary": "Descriptor-only workflow catalog summary.",
      "summaryOnly": true,
      "itemLimit": 8,
      "artifactWrite": false,
      "repositoryMutation": false,
      "privatePathEchoAllowed": false,
      "stdoutIncluded": false,
      "stderrIncluded": false,
      "rawLogIncluded": false,
      "fieldDescriptors": [
        {
          "fieldName": "workflowId",
          "valueKind": "bounded-string",
          "policy": "descriptor identifier only"
        },
        {
          "fieldName": "executionState",
          "valueKind": "enum",
          "policy": "must remain descriptor-only in this fixture"
        }
      ]
    },
    {
      "sectionId": "workflow_proposal_preview",
      "sourceBoundary": "pccx.lab.workflow-proposals.v0",
      "outputKind": "proposal_preview_section",
      "sectionState": "example_only",
      "summary": "Proposal-only command previews without execution.",
      "summaryOnly": true,
      "itemLimit": 8,
      "artifactWrite": false,
      "repositoryMutation": false,
      "privatePathEchoAllowed": false,
      "stdoutIncluded": false,
      "stderrIncluded": false,
      "rawLogIncluded": false,
      "fieldDescriptors": [
        {
          "fieldName": "proposalId",
          "valueKind": "bounded-string",
          "policy": "proposal identifier only"
        },
        {
          "fieldName": "fixedArgsPreview",
          "valueKind": "bounded-string-array",
          "policy": "structured argument preview; not a shell command string"
        }
      ]
    },
    {
      "sectionId": "workflow_result_summary",
      "sourceBoundary": "pccx.lab.workflow-results.v0",
      "outputKind": "result_summary_section",
      "sectionState": "example_only",
      "summary": "Summary-only workflow result metadata without full logs.",
      "summaryOnly": true,
      "itemLimit": 8,
      "artifactWrite": false,
      "repositoryMutation": false,
      "privatePathEchoAllowed": false,
      "stdoutIncluded": false,
      "stderrIncluded": false,
      "rawLogIncluded": false,
      "fieldDescriptors": [
        {
          "fieldName": "status",
          "valueKind": "enum",
          "policy": "copied from workflow result summary status"
        },
        {
          "fieldName": "summary",
          "valueKind": "bounded-string",
          "policy": "summary-only; no stdout, stderr, or raw logs"
        }
      ]
    }
  ],
  "sampleReport": {
    "reportId": "mcp-read-only-report-example",
    "reportState": "summary_only_fixture",
    "reportFormat": "bounded_json_summary",
    "overallStatus": "not_executed",
    "createdAt": "not-recorded",
    "sections": [
      {
        "sectionId": "lab_status_summary",
        "title": "Lab status",
        "summary": "Host status is available as deterministic metadata; hardware, timing, inference, and throughput remain unclaimed.",
        "sourceRef": "run-status.example.json",
        "evidenceState": "metadata-only",
        "itemCount": 1,
        "pathIncluded": false,
        "artifactWrite": false
      },
      {
        "sectionId": "workflow_descriptor_summary",
        "title": "Workflow descriptors",
        "summary": "Workflow descriptors are available as descriptor-only metadata.",
        "sourceRef": "workflow-descriptors.example.json",
        "evidenceState": "metadata-only",
        "itemCount": 4,
        "pathIncluded": false,
        "artifactWrite": false
      },
      {
        "sectionId": "workflow_proposal_preview",
        "title": "Workflow proposals",
        "summary": "Workflow proposals are previews only and do not execute commands.",
        "sourceRef": "workflow-proposals.example.json",
        "evidenceState": "metadata-only",
        "itemCount": 4,
        "pathIncluded": false,
        "artifactWrite": false
      },
      {
        "sectionId": "workflow_result_summary",
        "title": "Workflow results",
        "summary": "Workflow result summaries omit stdout, stderr, raw logs, generated artifacts, hardware logs, and provider logs.",
        "sourceRef": "workflow-results.example.json",
        "evidenceState": "summary-only",
        "itemCount": 1,
        "pathIncluded": false,
        "artifactWrite": false
      }
    ],
    "trackedFileMutation": false,
    "artifactWrite": false,
    "pathEchoAllowed": false,
    "stdoutIncluded": false,
    "stderrIncluded": false,
    "rawLogIncluded": false,
    "privatePathsIncluded": false,
    "generatedArtifactsIncluded": false
  },
  "outputPolicy": {
    "state": "planned",
    "summaryOnly": true,
    "approvalRequiredForPathInputs": true,
    "auditRequired": true,
    "commandExecutionByFixture": false,
    "trackedFileMutationAllowed": false,
    "artifactWriteAllowed": false,
    "pathEchoAllowed": false,
    "stdoutAllowed": false,
    "stderrAllowed": false,
    "rawLogAllowed": false,
    "privatePathsAllowed": false,
    "generatedArtifactsAllowed": false,
    "noMutationRule": "Future validation must prove tracked files are unchanged before and after producing a read-only analysis report.",
    "redactionRule": "Report output must omit private paths, secrets, tokens, model paths, stdout, stderr, raw logs, and generated artifact paths."
  },
