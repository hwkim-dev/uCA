{
  "schemaVersion": "pccx.lab.mcp-read-only-report-contract.v0",
  "tool": "pccx-lab",
  "contractId": "mcp-read-only-report-cli-core-contract",
  "contractState": "descriptor_only",
  "adapterState": "not_implemented",
  "defaultMode": "read_only",
  "automationPath": "cli-core-first-gui-independent",
  "entryBoundaryRefs": [
    {
      "refId": "analysis_flow",
      "schemaVersion": "pccx.lab.mcp-read-only-analysis-flow.v0",
      "examplePath": "docs/examples/mcp-read-only-analysis-flow.example.json",
      "state": "available_as_data"
    },
    {
      "refId": "tool_plan",
      "schemaVersion": "pccx.lab.mcp-read-only-tool-plan.v0",
      "examplePath": "docs/examples/mcp-read-only-tool-plan.example.json",
      "state": "available_as_data"
    },
    {
      "refId": "permission_model",
      "schemaVersion": "pccx.lab.mcp-permission-model.v0",
      "examplePath": "docs/examples/mcp-permission-model.example.json",
      "state": "available_as_data"
    },
    {
      "refId": "audit_event_shape",
