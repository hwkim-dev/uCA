  "safetyFlags": {
    "dataOnly": true,
    "descriptorOnly": true,
    "readOnly": true,
    "reportFixtureOnly": true,
    "mcpRuntimeImplemented": false,
    "mcpServerImplemented": false,
    "mcpClientImplemented": false,
    "commandExecution": false,
    "shellExecution": false,
    "runtimeExecution": false,
    "networkCalls": false,
