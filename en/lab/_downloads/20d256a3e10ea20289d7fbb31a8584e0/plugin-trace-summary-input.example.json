      "stderrIncluded": false,
      "rawLogIncluded": false,
      "rawTraceIncluded": false,
      "fieldDescriptors": [
        {
          "fieldName": "eventCount",
          "valueKind": "integer",
          "policy": "bounded count copied from an approved trace summary"
        },
        {
          "fieldName": "signalCount",
          "valueKind": "integer",
          "policy": "bounded count; no signal path names are included"
        },
        {
          "fieldName": "cycleRange",
          "valueKind": "integer-range",
          "policy": "start and end cycle numbers only"
        },
        {
          "fieldName": "eventKindCounts",
          "valueKind": "bounded-map",
          "policy": "event-kind counters only; no waveform values or raw trace rows"
        }
      ]
    }
  ],
  "sampleTraceSummary": {
    "sourceRef": "approved-trace-summary-json",
    "traceSummaryId": "trace-summary-placeholder-0001",
